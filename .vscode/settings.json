{
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/out": true,
    "**/build": true,
    "**/dist": true,
    "**/*.db": true,
    "**/*.log": true,
    "synth-1": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/out": true,
    "**/build": true,
    "**/dist": true,
    "**/*.db": true,
    "**/*.log": true,
    "synth-1": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/out/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/.turbo/**": true,
    "**/.swc/**": true,
    "**/coverage/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true,
    "**/.eslintcache": true,
    "**/.venv/**": true,
    "synth-1/**": true
  },
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    {
      "directory": "_ai-share/synth-1-full",
      "changeProcessCWD": true
    }
  ],
  "prettier.configPath": "_ai-share/synth-1-full/.prettierrc",
  "prettier.ignorePath": "_ai-share/synth-1-full/.prettierignore",
  "tailwindCSS.experimental.configFile": "_ai-share/synth-1-full/tailwind.config.ts",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "npm.autoDetect": "on"
}
