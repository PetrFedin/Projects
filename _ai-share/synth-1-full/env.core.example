# Platform Core — фокус на 3 столпах + встроенные блоки.
# Скопируйте в `.env.local` для dev на :3001 (рядом с full на :3000).
#
#   cp env.core.example .env.local
# Из корня монорепо Projects (по одной команде, без # в строке):
#   npm run core:bootstrap
#   npm run dev:core
#   npm run core:verify
#   npm run core:demo
#   npm run core:demo:check
#   npm run core:prep

PORT=3001
NEXT_PUBLIC_PLATFORM_CORE_MODE=1
NEXT_PUBLIC_BRAND_NAV_INVESTOR_SPINE=1
NEXT_PUBLIC_SHOP_NAV_INVESTOR_SPINE=1
NEXT_PUBLIC_FACTORY_NAV_INVESTOR_SPINE=1

# Workshop2 PostgreSQL (из корня: npm run db:core:up)
WORKSHOP2_DATABASE_URL=postgresql://workshop2:workshop2_dev@localhost:5433/workshop2
WORKSHOP2_DEV_BYPASS_AUTH=true
WORKSHOP2_ALLOW_SAME_ORIGIN_BROWSER=true

# Bootstrap PG (один раз после docker up):
#   npm run db:core:bootstrap
#   (миграции + SS27 dossiers + showroom publish + B2B demo + samples + chat)
# Smoke + e2e core (:3001, dev:core должен быть запущен):
#   npm run smoke:core
#   npm run test:e2e:core:external

# B2B inbound webhook (POST /api/integrations/v1/webhooks/shipment)
# Заголовок: x-integrations-spine-secret
# INTEGRATIONS_SPINE_WEBHOOK_SECRET=

# Spine operational persistence (INT-* wholesale orders, dev default: data/*.json)
# B2B_IMPORTED_ORDERS_FILE=
# B2B_INTEGRATION_META_FILE=
# B2B_OPERATIONAL_STATUS_FILE=
# B2B_DELIVERY_WINDOWS_FILE=
# B2B_ORDER_TRACKING_FILE=
# B2B_ALLOCATION_QUEUE_FILE=
# B2B_WORKING_ORDER_FILE=
# B2B_PRODUCTION_WIP_FILE=
# B2B_WHOLESALE_EXPORT_FILE=
# SPINE_IMPORTED_ORDERS_PG=1 when WORKSHOP2_DATABASE_URL set (default); 0 = file only
# Staging / prod cutover (ADR-002): PG-primary для operational spine в core dev
SPINE_OPERATIONAL_PG=1
SPINE_OPERATIONAL_PG_PRIMARY=1
# Platform Core (:3001): native W2/B2B/chat/tasks/dossier — только PostgreSQL (set 0 для JSON fallback)
# PLATFORM_CORE_SPINE_PG_PRIMARY=0
# WORKSHOP2_PG_ONLY=1
# Проверка: npm run core:verify:pg-primary (из корня Projects)
# Включить в существующий .env.local: npm run core:enable-pg-primary
# CI: npm run core:ci:pg-primary
#
# ShopProductionVisibility (default milestones) — brand UI на /brand/retailers;
# override env: NEXT_PUBLIC_SHOP_PRODUCTION_VISIBILITY=none|milestones|logistics|full
# B2B channel credentials (archive upstream → spine import)
# JOOR_API_BASE=  JOOR_ACCESS_TOKEN=
# NUORDER_HOSTNAME=  NUORDER_CONSUMER_KEY=  NUORDER_CONSUMER_SECRET=  NUORDER_OAUTH_TOKEN=  NUORDER_OAUTH_TOKEN_SECRET=
# ZEDONK_API_BASE=  ZEDONK_ACCESS_TOKEN=
# APPAREL_MAGIC_API_BASE=  APPAREL_MAGIC_API_TOKEN=

# OrbStack / Docker — SYNTHA пытается запустить автоматически при двойном клике

# Planner «Доработать» — Cursor SDK (агент на машине где крутится dev:core)
# Ключ: https://cursor.com/dashboard/integrations
# Установка runner (один раз из корня Projects): npm run planner:agent:install
# CURSOR_API_KEY=cursor_...
# iPhone/iPad: открывайте http://<IP-Mac>:3001/platform — агент стартует на Mac, не на телефоне
# Опционально cloud (без локального cwd): PLANNER_AGENT_RUNTIME=cloud + PLANNER_AGENT_CLOUD_REPO_URL=https://github.com/org/repo
