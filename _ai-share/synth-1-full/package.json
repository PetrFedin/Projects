{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "test": "node scripts/ensure-supported-node.mjs && jest",
    "test:contracts:b2b": "node scripts/ensure-supported-node.mjs && jest src/lib/b2b/integrations/__tests__/b2b-integration-public-response.schema.test.ts src/lib/b2b/integrations/__tests__/integration-export-persistence.test.ts src/lib/b2b/integrations/__tests__/b2b-export-domain-event.test.ts src/lib/order/__tests__/domain-event-outbox.test.ts src/lib/order/__tests__/domain-events-health.test.ts src/lib/server/__tests__/domain-event-outbox-cron-auth.test.ts src/lib/server/__tests__/domain-events-health.test.ts src/lib/server/__tests__/domain-events-health-route.test.ts src/lib/use-cases/b2b/__tests__/load-integrations-dashboard.test.ts src/lib/marketing/__tests__/crowd-sentiment.test.ts",
    "test:e2e": "node scripts/ensure-supported-node.mjs && node scripts/kill-e2e-port.cjs && playwright test",
    "test:e2e:api": "node scripts/ensure-supported-node.mjs && node scripts/kill-e2e-port.cjs && DOMAIN_EVENT_HEALTH_SECRET=e2e-domain-health-secret playwright test e2e/domain-events-health-api.spec.ts e2e/b2b-operational-orders-api.spec.ts e2e/b2b-integrations-dashboard-api.spec.ts e2e/b2b-export-order-api.spec.ts e2e/b2b-create-order-platform-export-ui.spec.ts e2e/b2b-catalog.spec.ts e2e/production.spec.ts e2e/shop-erp-analytics-strip.spec.ts --workers=1",
    "test:e2e:verification": "node scripts/ensure-supported-node.mjs && node scripts/kill-e2e-port.cjs && playwright test e2e/unified-ecosystem-smoke.spec.ts --workers=1",
    "test:e2e:light": "node scripts/ensure-supported-node.mjs && node scripts/kill-e2e-port.cjs && playwright test e2e/smoke.spec.ts --workers=1",
    "test:e2e:cabinet-hubs": "node scripts/ensure-supported-node.mjs && node scripts/kill-e2e-port.cjs && playwright test e2e/cabinet-hubs-smoke.spec.ts --workers=1",
    "test:e2e:shop-retail": "node scripts/ensure-supported-node.mjs && node scripts/kill-e2e-port.cjs && playwright test e2e/shop-erp-analytics-strip.spec.ts --workers=1",
    "test:e2e:heavy": "npm run test:e2e:verification && npm run test:e2e:api",
    "smoke:fast": "npm run check:contracts:ci",
    "normalize:tailwind-legacy": "node scripts/dev/normalize-legacy-tailwind-classes.mjs",
    "dev:e2e": "node scripts/ensure-supported-node.mjs && rm -rf .next/cache && NODE_OPTIONS=--max-old-space-size=6144 next dev --hostname 127.0.0.1 --port 3123",
    "dev:e2e:turbo": "node scripts/ensure-supported-node.mjs && next dev --turbopack --hostname 127.0.0.1 --port 3123",
    "format": "prettier --write \"{src,components,app}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{src,components,app}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md}\"",
    "typecheck": "node scripts/ensure-supported-node.mjs && NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:next-pages": "npm run -s build:isolated && NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit -p tsconfig.next-pages.json",
    "typecheck:order-subset": "node scripts/ensure-supported-node.mjs && tsc --noEmit -p tsconfig.strict-order.json",
    "check:legacy-archive-api": "node scripts/ci/legacy-archive-api-guard.mjs",
    "check:integrations-boundary": "node scripts/ci/integrations-client-server-boundary-guard.mjs",
    "check:ai-client-boundary": "node scripts/ci/ai-client-boundary-guard.mjs",
    "check:domain-events-health-contract": "node scripts/ci/check-domain-events-health-contract.mjs",
    "check:domain-events-health-contract:typed": "tsx --tsconfig tsconfig.json scripts/ci/check-domain-events-health-contract.ts",
    "check:domain-events-health-runner-parity": "node scripts/ci/check-domain-events-health-runner-parity.mjs",
    "check:contracts": "node scripts/ensure-supported-node.mjs && npm run -s check:legacy-archive-api && npm run -s check:integrations-boundary && npm run -s check:ai-client-boundary && npm run -s check:domain-events-health-runner-parity && npm run -s check:domain-events-health-contract",
    "check:contracts:ci": "node scripts/ensure-supported-node.mjs && npm run -s check:legacy-archive-api && npm run -s check:integrations-boundary && npm run -s check:ai-client-boundary && npm run -s check:domain-events-health-runner-parity && npm run -s check:domain-events-health-contract",
    "dev": "node scripts/ensure-supported-node.mjs && next dev --hostname 0.0.0.0 --port 3000",
    "kill-stale-dev": "bash ../scripts/stop-stale-next-dev.sh",
    "clean": "rm -rf .next node_modules/.cache .turbo",
    "reinstall": "node scripts/ensure-supported-node.mjs && rm -rf node_modules .next && npm install --no-audit --no-fund",
    "dev:clean": "node scripts/ensure-supported-node.mjs && npm run clean && next dev --hostname 0.0.0.0 --port 3000",
    "dev:webpack": "node scripts/ensure-supported-node.mjs && next dev --hostname 0.0.0.0 --port 3000",
    "dev:turbopack": "node scripts/ensure-supported-node.mjs && next dev --turbopack --hostname 0.0.0.0 --port 3000",
    "genkit:dev": "node scripts/ensure-supported-node.mjs && genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "node scripts/ensure-supported-node.mjs && genkit start -- tsx --watch src/ai/dev.ts",
    "build": "node scripts/ensure-supported-node.mjs && NODE_OPTIONS=--max-old-space-size=8192 NODE_ENV=production next build",
    "build:isolated": "rm -rf .next-isolated && NEXT_DIST_DIR=.next-isolated npm run build",
    "start": "node scripts/ensure-supported-node.mjs && next start",
    "lint": "node scripts/ensure-supported-node.mjs && next lint",
    "lint:errors": "node scripts/ensure-supported-node.mjs && next lint --quiet",
    "lint:fix": "node scripts/ensure-supported-node.mjs && next lint --fix",
    "schemas:validate": "node scripts/validate-schemas.mjs",
    "validate:category-handbook": "tsx --tsconfig tsconfig.json scripts/validate-category-handbook-snapshot.ts",
    "schemas:validate:examples": "node scripts/validate-schema-instances.mjs",
    "gen:category-handbook": "python3 scripts/generate-category-handbook.py",
    "gen:category-catalog": "tsx --tsconfig tsconfig.json scripts/gen-category-catalog.ts",
    "gen:tz-leaf-requirements": "node scripts/gen-tz-leaf-requirements.mjs",
    "prepare": "node -e \"const fs=require('fs');if(!fs.existsSync('.git'))process.exit(0)\" && husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@genkit-ai/google-genai": "^1.21.0",
    "@genkit-ai/next": "^1.21.0",
    "@hookform/resolvers": "^4.1.3",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@mui/material": "^7.3.6",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "framer-motion": "^11.5.7",
    "genkit": "^1.21.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "next": "^15.3.8",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-textarea-autosize": "^8.5.3",
    "recharts": "^2.15.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/recharts": "^1.8.29",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.24",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "genkit-cli": "^1.21.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
