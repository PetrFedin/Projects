{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "dev": "next dev --turbopack --hostname 0.0.0.0 --port 3000",
    "kill-stale-dev": "bash ../scripts/stop-stale-next-dev.sh",
    "clean": "rm -rf .next node_modules/.cache .turbo",
    "dev:clean": "npm run clean && next dev --turbopack --hostname 0.0.0.0 --port 3000",
    "dev:webpack": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:turbopack": "next dev --turbopack --hostname 0.0.0.0 --port 3000",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint src/lib lib --max-warnings 0",
    "lint:next": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"{src,components,app}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{src,components,app}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md}\"",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "typecheck:ci": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit -p tsconfig.ci.json",
    "schemas:validate": "node scripts/validate-schemas.mjs",
    "validate:category-handbook": "tsx --tsconfig tsconfig.json scripts/validate-category-handbook-snapshot.ts",
    "schemas:validate:examples": "node scripts/validate-schema-instances.mjs",
    "gen:category-handbook": "python3 scripts/generate-category-handbook.py",
    "gen:category-catalog": "tsx --tsconfig tsconfig.json scripts/gen-category-catalog.ts",
    "gen:tz-leaf-requirements": "node scripts/gen-tz-leaf-requirements.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "{src,components,app}/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "{src,components,app}/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@genkit-ai/google-genai": "^1.21.0",
    "@genkit-ai/next": "^1.21.0",
    "@hookform/resolvers": "^4.1.3",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@mui/material": "^7.3.6",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "framer-motion": "^11.5.7",
    "genkit": "^1.21.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "next": "15.3.8",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-textarea-autosize": "^8.5.3",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.12.12",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/recharts": "^1.8.29",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.24",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "genkit-cli": "^1.21.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
