# Пример для direnv: скопируйте в `.envrc` в этом каталоге (`cp .envrc.example .envrc`).
# Файл `.envrc` в git не коммитится (см. `.gitignore`).
#
# После `direnv allow` при каждом `cd` в каталог подтянется версия Node из `.nvmrc` через nvm.

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
  nvm use
fi
