# Скопируйте фрагмент в .env.local и подставьте значения.
# Полный чеклист: npm run w2:techpack:preflight
# CI: шаблон workflow — docs/ci/W2_TECHPACK_PREFLIGHT_GITHUB.yml

# --- Общее S3 (w2-metrics + tech pack под …/techpack/…) ---
W2_METRICS_S3_BUCKET=your-bucket
W2_METRICS_S3_REGION=eu-central-1
W2_METRICS_S3_ACCESS_KEY_ID=AKIA...
W2_METRICS_S3_SECRET_ACCESS_KEY=...
# Опционально; по умолчанию w2-metrics → префикс …/techpack/ в коде
# W2_METRICS_S3_PREFIX=w2-metrics

# --- Индекс вложений (Postgres) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Секреты API tech pack (не коммитить) ---
W2_TECHPACK_API_SECRET=replace-with-long-random
# Опционально: только скачивание для фабрики (иначе read = тот же API secret)
# W2_TECHPACK_FACTORY_READ_SECRET=...

# Прод: кабинет same-origin без ключа в JS-бандле
W2_TECHPACK_ALLOW_SAME_ORIGIN_BROWSER=1

# Локальная разработка (не в production):
# W2_TECHPACK_AUTH_DISABLED=1

# Опционально: JSON-логи в файл (ротация на стороне агента)
# W2_TECHPACK_OPS_LOG_PATH=/var/log/w2-techpack-ops.ndjson

# Отключить выгрузку в S3 (presign/complete = 503):
# W2_TECHPACK_REMOTE=0

# Опционально: замкнуть список статусов handoff (через запятую)
# W2_TECHPACK_HANDOFF_STATUSES=none,pending,sent,ack,rejected

# Только если API вызывается не с того же origin (нежелательно):
# NEXT_PUBLIC_W2_TECHPACK_API_KEY=same-as-W2_TECHPACK_API_SECRET

# --- Паспорт: регион пошива (GET /api/brand/sewing-plan-reference) ---
# Полный список партнёров вместо каталога брендов + демо (JSON-массив id/label):
# B2B_SEWING_PARTNERS_JSON=[{"id":"partner-1","label":"Цех А · Иваново"}]
#
# Доп. субъекты РФ (ISO 3166-2), сливаются с базовым списком; при совпадении кода — перекрывают имя:
# RF_FEDERAL_SUBJECT_EXTRA_JSON=[{"iso31662":"RU-XXX","name":"Новый субъект (пример)"}]
