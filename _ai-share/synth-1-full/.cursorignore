# ============================================================
# .cursorignore — Оптимизация расхода токенов
# Файлы здесь НЕ удаляются, но Cursor не индексирует их.
# Если нужно поработать с файлом — временно закомментируйте строку.
# ============================================================

# ── Зависимости и сборка ──
node_modules/
.npm/
.next/
out/
build/
dist/
.cache/
.turbo/
**/.swc/
**/.eslintcache
**/playwright-report/
**/test-results/
**/coverage/
tsconfig.tsbuildinfo

# ── Логи и артефакты ──
*.log
**/*.bak.*
**/*.old
**/*.tmp
*.txt
*.bak.tsx
docs/

# ── Секреты ──
.env*
*.pem
*.key

# ── Системные ──
.DS_Store
.idx/
backup_duplicates/

# ── Данные и БД ──
*.db
**/data/*.json
src/lib/product-attributes.ts
src/components/home/_fixtures/

# ── AI-контексты ──
.ai_context/
.ai_reports/

# ── Старые / неиспользуемые ──
messages-os.bak.tsx

