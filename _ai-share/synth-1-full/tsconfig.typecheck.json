{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "*.config.cts",
    "*.config.mjs",
    "*.config.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tailwind.config.ts"
  ],
  "exclude": [
    "node_modules",
    "backup_duplicates",
    "components",
    ".next",
    ".next-isolated",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
