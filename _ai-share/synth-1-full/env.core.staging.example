# Platform Core — staging / preview deploy
# Скопируйте в переменные окружения хостинга (Railway, Render, VPS).

NEXT_PUBLIC_PLATFORM_CORE_MODE=1
NEXT_PUBLIC_BRAND_NAV_INVESTOR_SPINE=1
NEXT_PUBLIC_SHOP_NAV_INVESTOR_SPINE=1
NEXT_PUBLIC_FACTORY_NAV_INVESTOR_SPINE=1

# Managed PostgreSQL (замените на URL провайдера)
WORKSHOP2_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/workshop2

# Публичный URL staging (для webhooks / deep links)
# WORKSHOP2_STAGING_PUBLIC_URL=https://core-staging.example.com

# --- Deploy checklist (Railway / Render / VPS) ---
# 1. Postgres addon → WORKSHOP2_DATABASE_URL
# 2. Env: NEXT_PUBLIC_PLATFORM_CORE_MODE=1 + investor spine flags (см. выше)
# 3. НЕ ставить WORKSHOP2_DEV_BYPASS_AUTH на staging/prod
# 4. Build: npm run build && Start: npm run start (PORT из платформы)
# 5. После deploy: npm run db:core:bootstrap (один раз, с DATABASE_URL на сервере)
# 6. Verify:
#    CORE_SMOKE_BASE_URL=https://your-host npm run smoke:core
#    PLAYWRIGHT_BASE_URL=https://your-host PLAYWRIGHT_SKIP_WEBSERVER=1 npm run test:e2e:core:external
