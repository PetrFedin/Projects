{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ]
    },
    "git": {
      "command": "python3",
      "args": [
        "-m",
        "mcp_server_git",
        "--repository",
        "${workspaceFolder}"
      ]
    },
    "fetch": {
      "command": "python3",
      "args": [
        "-m",
        "mcp_server_fetch"
      ]
    },
    "agent-browser": {
      "command": "npx",
      "args": [
        "-y",
        "agent-browser-mcp"
      ]
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "linear": {
      "url": "https://mcp.linear.app/mcp",
      "transport": "http"
    },
    "semgrep": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-semgrep"
      ],
      "env": {
        "PATH": "/Users/petr/Library/Python/3.14/bin:/Users/petr/Library/Python/3.14/bin:/Applications/Cursor.app/Contents/Resources/app/resources/helpers:/Users/petr/.nvm/versions/node/v22.22.2/bin:/Library/Frameworks/Python.framework/Versions/3.14/bin:/usr/local/bin:/System/Cryptexes/App/usr/bin:/usr/bin:/bin:/usr/sbin:/sbin:/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/local/bin:/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/bin:/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/appleinternal/bin:/opt/pmk/env/global/bin:/Library/Apple/usr/bin"
      }
    }
  }
}
