# ============================================================
# Root .cursorignore — минимизация расхода токенов
# ============================================================

# ── Стандартное ──
**/node_modules/
.venv/
.git
dist
build
coverage
logs
tmp
cache
*.log
*.csv
*.png
*.jpg
*.jpeg
*.webp
*.mp4
*.zip
**/*.bak.*
**/*.old
**/*.tmp
*.txt

# ── Сборка Next.js / фронт-кэши (не исходники) ──
synth-1/.next/
**/.next/
**/out/
**/.turbo/
**/.swc/
**/.vercel/
**/*.tsbuildinfo

# ── Тесты, линтер, отчёты (только артефакты) ──
**/playwright-report/
**/test-results/
**/coverage/
**/.eslintcache
**/.parcel-cache/
**/storybook-static/

# ── БД (бинарные файлы, бесполезны для AI) ──
*.db

# ── AI-артефакты ──
.ai_context/
.ai_reports/

# ── Пустые MD-файлы (0 строк, только шум) ──
DEVELOPMENT_PLAN.md
SESSION_PROTOCOL.md
CODE_QUALITY_RULES.md
SELF_IMPROVEMENT.md
REVIEW_CHECKLIST.md
MODULE_TEMPLATE.md
PROMPT_RULES.md

# ── GitHub / CI ──
.github/
.pre-commit-config.yaml

# ── Дополнительно: Python/JS артефакты ──
**/__pycache__
**/*.pyc
.pytest_cache
.mypy_cache
.ruff_cache

# ── Разовые скрипты ──
fix_*.py
move_*.py
restore_*.py
replace_*.py
