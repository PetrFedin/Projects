# Synth-1 Fashion OS — local development
# Copy to .env and adjust

# PostgreSQL 17 (primary)
# macOS Homebrew: use your login name (whoami), usually no password — NOT "postgres"
# Example: postgresql+asyncpg://petr@localhost:5432/synth1
DATABASE_URL=postgresql+asyncpg://petr@localhost:5432/synth1

# Platform Core / Workshop2 PG (OrbStack, port 5433)
WORKSHOP2_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/workshop2

# Redis 8
REDIS_URL=redis://localhost:6379/0

# Security / JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=11520
AUTH_USE_DB=false

# AI — Ollama local (preferred)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3
AI_MODEL=qwen3

# AI — cloud fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=

# Payments
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
STRIPE_SECRET_KEY=
TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=

# Firebase (optional backend token exchange)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Media uploads
MEDIA_UPLOAD_DIR=static/media

# Frontend (in _ai-share/synth-1-full/.env.local)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_USE_FASTAPI=true
