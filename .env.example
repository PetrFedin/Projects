# Synth-1 Fashion OS - Environment variables
# Copy to .env and fill in values

# Database
DATABASE_URL=sqlite+aiosqlite:///./synth1.db

# Security
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development

# --- РФ Интеграции ---

# Честный ЗНАК (CRPT) - https://markirovka.crpt.ru
CRPT_CLIENT_ID=
CRPT_CLIENT_SECRET=

# ЭДО (Диадок)
EDO_PROVIDER=diadoc
DIADOC_API_KEY=

# 1С
C1C_BASE_URL=https://your-1c-server/hs/syntha
C1C_USER=
C1C_PASSWORD=

# СДЭК - https://api.cdek.ru
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# Endpoint usage audit (collects hit counts for GET /api/v1/admin/endpoint-stats)
ENABLE_ENDPOINT_STATS=false
# MVP guard: disable all external API calls (CRPT/EDO/1C/CDEK/payments)
ENABLE_EXTERNAL_APIS=false

# AI / LLM (Gemini)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Скетч / производство (Next.js client — только NEXT_PUBLIC_*)
# POST критичных меток в MES/ERP (JSON: pathLabel, sku, leafId, criticalPins[])
NEXT_PUBLIC_SKETCH_CRITICAL_WEBHOOK_URL=
# Генерация изображений каталога (скетч «Демо: ИИ-референс»): POST body из CatalogImageGenRequest
NEXT_PUBLIC_CATALOG_IMAGE_GEN_URL=

# AI task rate limit (per user per window)
# AI_TASK_RATE_LIMIT=20
# AI_TASK_RATE_WINDOW=60

# Оплата (Тинькофф Acquiring)
PAYMENT_PROVIDER=tinkoff
TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=

# Marketplace (Shopify, Ozon, WB) — MVP stub when empty
# SHOPIFY_SHOP_URL=https://your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=
# OZON_CLIENT_ID=
# OZON_API_KEY=
# WB_API_KEY=

# --- synth-1 Next.js (положите в synth-1/.env.local при необходимости) ---
# По умолчанию UI без внешнего platform API: transport=local, base URL пустой.
# NEXT_PUBLIC_SYNTH_PLATFORM_TRANSPORT=local
# NEXT_PUBLIC_SYNTH_API_BASE_URL=
# Бэкенд FastAPI для auth/профиля (локально): http://127.0.0.1:8000/api/v1
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
