# Synth-1 Fashion OS - Environment variables
# Copy to .env and fill in values

# Database
DATABASE_URL=sqlite+aiosqlite:///./synth1.db

# Security
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development

# --- РФ Интеграции ---

# Честный ЗНАК (CRPT) - https://markirovka.crpt.ru
CRPT_CLIENT_ID=
CRPT_CLIENT_SECRET=

# ЭДО (Диадок)
EDO_PROVIDER=diadoc
DIADOC_API_KEY=

# 1С
C1C_BASE_URL=https://your-1c-server/hs/syntha
C1C_USER=
C1C_PASSWORD=

# СДЭК - https://api.cdek.ru
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# Endpoint usage audit (collects hit counts for GET /api/v1/admin/endpoint-stats)
ENABLE_ENDPOINT_STATS=false
# MVP guard: disable all external API calls (CRPT/EDO/1C/CDEK/payments)
ENABLE_EXTERNAL_APIS=false

# AI / LLM (Gemini)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Скетч / производство (Next.js client — только NEXT_PUBLIC_*)
# POST критичных меток в MES/ERP (JSON: pathLabel, sku, leafId, criticalPins[])
NEXT_PUBLIC_SKETCH_CRITICAL_WEBHOOK_URL=
# Генерация изображений каталога (скетч «Демо: ИИ-референс»): POST body из CatalogImageGenRequest
NEXT_PUBLIC_CATALOG_IMAGE_GEN_URL=

# AI task rate limit (per user per window)
# AI_TASK_RATE_LIMIT=20
# AI_TASK_RATE_WINDOW=60

# Оплата (Тинькофф Acquiring)
PAYMENT_PROVIDER=tinkoff
TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=

# Marketplace (Shopify, Ozon, WB) — MVP stub when empty
# SHOPIFY_SHOP_URL=https://your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=
# OZON_CLIENT_ID=
# OZON_API_KEY=
# WB_API_KEY=

# --- synth-1 Next.js (положите в synth-1/.env.local при необходимости) ---
# По умолчанию UI без внешнего platform API: transport=local, base URL пустой.
# NEXT_PUBLIC_SYNTH_PLATFORM_TRANSPORT=local
# NEXT_PUBLIC_SYNTH_API_BASE_URL=
# Бэкенд FastAPI для auth/профиля (локально): http://127.0.0.1:8000/api/v1
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Workshop2 досье-метрики (Next synth-1): чтение GET — Bearer / X-W2-Metrics-Key
# W2_DOSSIER_METRICS_READ_SECRET=
# Прод: Upstash / Vercel KV (иначе NDJSON на диске — на serverless не персистентно)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Локальный файл (override пути): W2_DOSSIER_METRICS_FILE=
# Не слать appUserUid/orgId с клиента: NEXT_PUBLIC_W2_DOSSIER_METRICS_DISABLE_USER_CONTEXT=1
# Не сохранять uid/org в хранилище: W2_DOSSIER_METRICS_STRIP_USER_IDS=1
# Подписанный stamp (сервер): W2_DOSSIER_METRICS_STAMP_SECRET= (обязателен для выдачи stamp)
# Выдача stamp для скриптов: W2_DOSSIER_METRICS_MINT_BEARER= (Bearer тот же в Authorization)
# MVP без API, доверенный Origin: W2_DOSSIER_METRICS_LOOSE_STAMP=1 и W2_DOSSIER_METRICS_TRUSTED_ORIGINS=yourdomain.com
# Клиент шлёт X-W2-Metrics-Stamp: NEXT_PUBLIC_W2_METRICS_STAMP_ENABLED=true
# Разрешить uid/org без stamp (миграция): W2_DOSSIER_METRICS_ALLOW_UNSTAMPED_IDS=1
# Архив метрик (cron): W2_METRICS_CRON_SECRET= или CRON_SECRET=
# W2_METRICS_ARCHIVE_PUT_URL= (presigned PUT) или W2_METRICS_ARCHIVE_LOCAL_DIR=./data/w2-metrics-archive
# W2_METRICS_ARCHIVE_READ_LIMIT=5000
# Идемпотентность cron: W2_METRICS_ARCHIVE_STATE_FILE= (по умолчанию data/w2-metrics-archive-state.json)
# Повторить выгрузку тем же срезом: GET .../w2-dossier-metrics-archive?force=1
# Webhook после архива: W2_METRICS_ARCHIVE_WEBHOOK_URL= (общий секрет подписи: W2_METRICS_WEBHOOK_SECRET=)
# Redis: длина списка W2_UPSTASH_METRICS_MAX_LEN= или W2_METRICS_REDIS_MAX_LEN= (1000–50000)
# POST метрик: полный JSON в лог — W2_DOSSIER_METRICS_VERBOSE_POST_LOG=1
# Алерты (пороги): W2_OPS_STALE_HOURS= W2_OPS_PASSPORT_MIN_ARTICLES= W2_OPS_PASSPORT_RATIO_WARN_BELOW=
# W2_OPS_ABANDON_MIN_RAW= W2_OPS_ABANDON_RATIO_WARN_ABOVE=
# Алерты во внешку: W2_OPS_ALERT_WEBHOOK_URL= и W2_OPS_ALERT_SINCE_HOURS= (для Vercel cron без query)
# Чтение метрик: IP allowlist (точные IP через запятую) W2_DOSSIER_METRICS_READ_IP_ALLOWLIST=
# POST метрик: rate limit W2_DOSSIER_METRICS_POST_RL_PER_MIN= (дефолт 180), опциональный секрет W2_DOSSIER_METRICS_POST_SECRET=
# Браузер с секретом (ключ в клиенте — только для закрытых сборок): NEXT_PUBLIC_W2_DOSSIER_METRICS_WRITE_KEY=
# LOOSE_STAMP в production: только с W2_DOSSIER_METRICS_LOOSE_STAMP_ALLOW_PRODUCTION=1
# S3 без presigned: W2_METRICS_S3_BUCKET= W2_METRICS_S3_REGION= W2_METRICS_S3_ACCESS_KEY_ID= W2_METRICS_S3_SECRET_ACCESS_KEY= W2_METRICS_S3_PREFIX=w2-metrics
# После успешного архива очистить hot-источник (осторожно): W2_METRICS_ARCHIVE_AFTER_SUCCESS_CLEAR_REDIS=1 и/или W2_METRICS_ARCHIVE_AFTER_SUCCESS_TRUNCATE_FILE=1
